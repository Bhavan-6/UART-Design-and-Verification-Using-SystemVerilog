tb_top.sv
Verilog
module tb_top;

    logic clk;
    logic reset;

    // Clock Generation
    initial begin
        clk = 0;
        forever #10 clk = ~clk;
    end

    // Reset Generation
    initial begin
        reset = 1;
        #20 reset = 0;
    end

    // Interface Instance
    uart_if vif(clk, reset);

    // DUT Instance
    uart_top DUT (
        .clk(vif.clk),
        .reset(vif.reset),
        .tx_start(vif.tx_start),
        .tx_data(vif.tx_data),
        .rx_data(vif.rx_data),
        .tx_done(vif.tx_done),
        .rx_done(vif.rx_done),
        .parity_error(vif.parity_error),
        .framing_error(vif.framing_error)
    );

    // Test Instance
    test t;

    // Waveform Dump
    initial begin
        $dumpfile("uart.vcd");
        $dumpvars(0, tb_top);
    end

    // Start Test
    initial begin
        t = new(vif);
        t.run();
    end

    // Safety Timeout
    initial begin
        #10ms;
        $display("Error: Simulation Timeout!");
        $finish;
    end

endmodule
