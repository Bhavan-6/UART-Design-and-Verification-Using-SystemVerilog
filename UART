transaction.sv
Verilog
class transaction;
    rand bit [7:0] tx_data;
    bit [7:0]      rx_data;
    bit            tx_done;
    bit            rx_done;
    bit            parity_error;
    bit            framing_error;

    function void display(string name);
        $display("-----------------------------------------");
        $display("[%s] TX DATA        = %h", name, tx_data);
        $display("     RX DATA        = %h", name, rx_data);
        $display("     TX DONE        = %b", name, tx_done);
        $display("     RX DONE        = %b", name, rx_done);
        $display("     PARITY ERROR   = %b", name, parity_error);
        $display("     FRAMING ERROR  = %b", name, framing_error);
        $display("-----------------------------------------");
    endfunction
endclass
generator.sv
Verilog
class generator;
    transaction tr;
    mailbox gen2drv;

    function new(mailbox gen2drv);
        this.gen2drv = gen2drv;
    endfunction

    task run();
        repeat(20) begin
            tr = new();
            if (!tr.randomize()) $error("Randomization Failed");
            tr.display("GENERATOR");
            gen2drv.put(tr);
        end
    endtask
endclass
driver.sv
Verilog
class driver;
    virtual uart_if vif;
    mailbox gen2drv;
    transaction tr;

    function new(virtual uart_if vif, mailbox gen2drv);
        this.vif     = vif;
        this.gen2drv = gen2drv;
    endfunction

    task reset();
        vif.tx_start      <= 0;
        vif.tx_data       <= 0;
        $display("--------------------------------");
        $display(" DRIVER : RESET COMPLETED ");
        $display("--------------------------------");
    endtask

    task run();
        forever begin
            gen2drv.get(tr);
            vif.tx_start <= 1'b1;
            vif.tx_data  <= tr.tx_data;
            @(posedge vif.clk);
            vif.tx_start <= 1'b0;
            
            // Wait for transmission to finish
            wait(vif.tx_done == 1'b1);
            @(posedge vif.clk);
        end
    endtask
endclass
monitor.sv
Verilog
class monitor;
    virtual uart_if vif;
    mailbox mon2scb;
    transaction tr;

    function new(virtual uart_if vif, mailbox mon2scb);
        this.vif     = vif;
        this.mon2scb = mon2scb;
    endfunction

    task run();
        forever begin
            tr = new();
            wait(vif.rx_done == 1'b1);
            tr.rx_data       = vif.rx_data;
            tr.rx_done       = vif.rx_done;
            tr.parity_error  = vif.parity_error;
            tr.framing_error = vif.framing_error;
            mon2scb.put(tr);
            @(posedge vif.clk);
        end
    endtask
endclass
