baud_gen.sv
Verilog
module baud_gen #(
    parameter CLK_FREQ  = 50000000,
    parameter BAUD_RATE = 9600
)(
    input  wire clk,
    input  wire reset,
    output reg  baud_clk
);

    localparam integer COUNT_MAX = CLK_FREQ / (BAUD_RATE * 16);
    integer count;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            count    <= 0;
            baud_clk <= 0;
        end else begin
            if (count == COUNT_MAX - 1) begin
                count    <= 0;
                baud_clk <= ~baud_clk;
            end else begin
                count    <= count + 1;
            end
        end
    end

endmodule
uart_tx.sv
Verilog
module uart_tx #(
    parameter DATA_WIDTH = 8
)(
    input  wire                  clk,
    input  wire                  reset,
    input  wire                  tx_start,
    input  wire [DATA_WIDTH-1:0] tx_data,
    output reg                   tx,
    output reg                   tx_done
);

    typedef enum logic [1:0] {
        IDLE  = 2'b00,
        START = 2'b01,
        DATA  = 2'b10,
        STOP  = 2'b11
    } state_t;

    state_t state;
    integer bit_index;
    reg [DATA_WIDTH-1:0] tx_shift_reg;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state        <= IDLE;
            tx           <= 1'b1;
            tx_done      <= 1'b0;
            bit_index    <= 0;
            tx_shift_reg <= 0;
        end else begin
            case (state)
                IDLE: begin
                    tx      <= 1'b1;
                    tx_done <= 1'b0;
                    if (tx_start) begin
                        tx_shift_reg <= tx_data;
                        state        <= START;
                    end
                end

                START: begin
                    tx    <= 1'b0;
                    state <= DATA;
                end

                DATA: begin
                    tx <= tx_shift_reg[bit_index];
                    if (bit_index == DATA_WIDTH - 1) begin
                        bit_index <= 0;
                        state     <= STOP;
                    end else begin
                        bit_index <= bit_index + 1;
                    end
                end

                STOP: begin
                    tx      <= 1'b1;
                    tx_done <= 1'b1;
                    state   <= IDLE;
                end
            endcase
        end
    end

endmodule
uart_rx.sv
Verilog
module uart_rx #(
    parameter DATA_WIDTH = 8
)(
    input  wire                  clk,
    input  wire                  reset,
    input  wire                  rx,
    output reg  [DATA_WIDTH-1:0] rx_data,
    output reg                   rx_done,
    output reg                   parity_error,
    output reg                   framing_error
);

    typedef enum logic [1:0] {
        IDLE  = 2'b00,
        START = 2'b01,
        DATA  = 2'b10,
        STOP  = 2'b11
    } state_t;

    state_t state;
    integer bit_index;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state         <= IDLE;
            rx_data       <= 0;
            rx_done       <= 1'b0;
            parity_error  <= 1'b0;
            framing_error <= 1'b0;
            bit_index     <= 0;
        end else begin
            case (state)
                IDLE: begin
                    rx_done <= 1'b0;
                    if (!rx) begin
                        state <= START;
                    end
                end

                START: begin
                    state <= DATA;
                end

                DATA: begin
                    rx_data[bit_index] <= rx;
                    if (bit_index == DATA_WIDTH - 1) begin
                        bit_index <= 0;
                        state     <= STOP;
                    end else begin
                        bit_index <= bit_index + 1;
                    end
                end

                STOP: begin
                    if (rx == 1'b1) begin
                        rx_done       <= 1'b1;
                        framing_error <= 1'b0;
                    end else begin
                        framing_error <= 1'b1;
                    end
                    state <= IDLE;
                end
            endcase
        end
    end

endmodule
uart_top.sv
Verilog
module uart_top #(
    parameter DATA_WIDTH = 8
)(
    input  wire                  clk,
    input  wire                  reset,
    input  wire                  tx_start,
    input  wire [DATA_WIDTH-1:0] tx_data,
    output wire [DATA_WIDTH-1:0] rx_data,
    output wire                  tx_done,
    output wire                  rx_done,
    output wire                  parity_error,
    output wire                  framing_error
);

    wire baud_clk;
    wire loopback_line;

    baud_gen bg_inst (
        .clk(clk),
        .reset(reset),
        .baud_clk(baud_clk)
    );

    uart_tx #(
        .DATA_WIDTH(DATA_WIDTH)
    ) tx_inst (
        .clk(baud_clk),
        .reset(reset),
        .tx_start(tx_start),
        .tx_data(tx_data),
        .tx(loopback_line),
        .tx_done(tx_done)
    );

    uart_rx #(
        .DATA_WIDTH(DATA_WIDTH)
    ) rx_inst (
        .clk(baud_clk),
        .reset(reset),
        .rx(loopback_line),
        .rx_data(rx_data),
        .rx_done(rx_done),
        .parity_error(parity_error),
        .framing_error(framing_error)
    );

endmodule
